# -----------------------------------------------------------------------------
# WanVace basic paths
# -----------------------------------------------------------------------------

# Video output directory. OUTPUT_DIR and SAVE_FOLDER_PATH are also supported.
WANVACE_OUTPUT_DIR=./outputs


# -----------------------------------------------------------------------------
# LTX2 required paths
# -----------------------------------------------------------------------------
# Required for LTX2-TI2Vid-HQ and LTX2-A2Vid.
# Download model files from the official Lightricks LTX-2.3 HuggingFace repo.

# Local clone of https://github.com/Lightricks/LTX-2
LTX2_ROOT=/home/arkstone/workspace/LTX-2

# Main LTX2 checkpoint, e.g. ltx-2.3-22b-dev.safetensors or
# ltx-2.3-22b-distilled-1.1.safetensors.
LTX2_CHECKPOINT_PATH=/path/to/ltx-2.3-22b-dev.safetensors

# Distilled LoRA required by current two-stage pipelines.
LTX2_DISTILLED_LORA_PATH=/path/to/ltx-2.3-22b-distilled-lora-384-1.1.safetensors

# Spatial upsampler required by current two-stage pipelines.
LTX2_SPATIAL_UPSAMPLER_PATH=/path/to/ltx-2.3-spatial-upscaler-x2-1.1.safetensors

# Local Gemma text encoder directory. Use the full model directory, not a single file.
LTX2_GEMMA_ROOT=/path/to/gemma-3-12b-it-qat-q4_0-unquantized


# -----------------------------------------------------------------------------
# LTX2 quality / conditioning knobs
# -----------------------------------------------------------------------------
# These defaults are conservative. Change only when you want to tune behavior.

# Distilled LoRA strength for TI2Vid-HQ stage 1 and stage 2.
LTX2_DISTILLED_LORA_STRENGTH_STAGE_1=0.25
LTX2_DISTILLED_LORA_STRENGTH_STAGE_2=0.5

# Image conditioning strength. 1.0 keeps strong first/keyframe conditioning.
LTX2_IMAGE_STRENGTH=1.0

# Image conditioning compression CRF. Lower means less compression; 0 is lossless.
LTX2_IMAGE_CRF=33


# -----------------------------------------------------------------------------
# LTX2 performance / memory optimization
# -----------------------------------------------------------------------------
# Leave these blank/off unless you are testing a specific tradeoff.

# Optional transformer compile. First run is slower due to compilation; later runs
# with the same shapes may be faster. Dynamic resolutions can reduce the benefit.
LTX2_TORCH_COMPILE=false

# Optional quantization. Blank disables it.
# Supported values:
#   fp8-cast       Lower VRAM, no TensorRT-LLM dependency.
#   fp8-scaled-mm  Requires TensorRT-LLM and suitable FP8 checkpoints; best on Hopper.
LTX2_QUANTIZATION=

# Optional layer streaming. Blank disables it.
# Example: 2 streams transformer layers from CPU to GPU with two-layer prefetch.
# This lowers VRAM but can be slower and uses more CPU/RAM/PCIe bandwidth.
LTX2_STREAMING_PREFETCH_COUNT=

# Maximum batch size for transformer forward splitting. Default 1 is safest.
# Values >1 can reduce layer-streaming transfer overhead but may increase VRAM.
LTX2_MAX_BATCH_SIZE=1
